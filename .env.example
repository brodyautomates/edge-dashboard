# ─────────────────────────────────────────────────────────────────────────────
# EDGE — Sports Betting Intelligence Dashboard
# Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys before running.
# NEVER commit your .env file to version control.

# The Odds API — Required for live odds data
# Get your free key at: https://the-odds-api.com (500 req/month free)
VITE_ODDS_API_KEY=your_odds_api_key_here

# Refresh interval in milliseconds (default: 300000 = 5 minutes)
# Free tier: keep this at 300000 or higher to stay within quota
VITE_ODDS_REFRESH_MS=300000
